{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "maven-package",
      "type": "shell",
      "command": "mvn package",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "clear": true,
        "panel": "shared"
      },
      "problemMatcher": [
        "$msCompile"
      ]
    }
  ]
}
